    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/passport-jwt": "^4.0.1",
    "@vercel/node": "^3.2.0",
    "jest": "^29.7.0",
    "prisma": "^5.18.0",
