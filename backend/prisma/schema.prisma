// BienestAPP — esquema de base de datos (PostgreSQL / Prisma)
// Dominios lógicos: operativo, emocional, clínico (ver docs/DATABASE.md)
// Datos sensibles marcados con // SENSITIVE → cifrar a nivel de servicio (envelope encryption)

generator client {
  provider = "prisma-client-js"
  // 'native' para dev local; 'rhel-openssl-3.0.x' para el runtime serverless de Vercel.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Runtime: conexión POOLED de Supabase (pgbouncer, puerto 6543) — apta para serverless/Vercel.
  url       = env("DATABASE_URL")
  // Migraciones / introspección: conexión DIRECTA (puerto 5432).
  directUrl = env("DIRECT_URL")
}

// ───────────────────────── Enums ─────────────────────────

enum RoleName {
  AFFILIATE
  CALLCENTER_OPERATOR
  PSYCHOLOGIST
  PHYSICIAN
  NUTRITIONIST
  NURSE
  SOCIAL_WORKER
  FIELD_DOCTOR
  EPS_ADMIN
  SUPERADMIN
  AUDITOR
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum RiskLevel {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskSource {
  JOURNAL
  AI_CHAT
  TEST
  SOS
  MANUAL
}

enum EmergencyType {
  MEDICAL
  EMOTIONAL_CRISIS
  ACCIDENT
  VIOLENCE
  OTHER
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  ESCALATED
  CLOSED
}

enum CaseStatus {
  NEW
  IN_PROGRESS
  ESCALATED
  CLOSED
}

enum ConsentType {
  INFORMED_CONSENT
  AI_PROCESSING
  LOCATION
  NOTIFICATIONS
  EMERGENCY_CONTACT_NOTIFY
  DATA_SHARING
}

enum MoodLabel {
  ANXIETY
  STRESS
  SADNESS
  MOTIVATION
  TIREDNESS
  GRATITUDE
  CALM
  ANGER
  JOY
}

enum AiAction {
  NORMAL
  CONTAINMENT
  ESCALATED
  BLOCKED
}

enum NotificationType {
  REMINDER
  ACHIEVEMENT
  RISK_ALERT
  CALLCENTER
  SYSTEM
}

// ───────────────────────── RBAC ─────────────────────────

model Role {
  id          String           @id @default(cuid())
  name        RoleName         @unique
  description String?
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique // e.g. "callcenter.case.read"
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

// ───────────────────────── Operativo ─────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  nit       String?  @unique
  users     User[]
  createdAt DateTime @default(now())
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  passwordHash   String
  status         UserStatus @default(ACTIVE)
  mfaEnabled     Boolean    @default(false)
  mfaSecret      String? // SENSITIVE
  epsCode        String? // EPS prestadora a la que pertenece el afiliado (ver model Eps)
  chatLastSeenAt DateTime? // presencia en el chat (en línea / última vez)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  roles            UserRole[]
  profile          AffiliateProfile?
  consents         Consent[]
  emergencyContacts EmergencyContact[]
  moodEntries      MoodEntry[]
  journalEntries   JournalEntry[]
  conversations    AIConversation[]
  riskAssessments  RiskAssessment[]
  emergencyTickets EmergencyTicket[]
  foodLogs         FoodLog[]
  exerciseLogs     ExerciseLog[]
  habits           Habit[]
  goals            Goal[]
  medicationItems  MedicationItem[]
  pqrs             Pqrs[]
  communityPosts   CommunityPost[]
  healthMetrics    HealthMetric[]
  healthConnections HealthConnection[]
  signedDocuments  SignedDocument[]
  pet              VirtualPet?
  achievements     UserAchievementCard[]
  testResults      TestResult[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  refreshTokens    RefreshToken[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model AffiliateProfile {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName     String
  lastName      String
  documentType  String?
  documentNumber String?  // SENSITIVE
  birthDate     DateTime?
  phone         String?
  avatarPath    String? // ruta en Supabase Storage (avatar)
  bio           String?
  // preferencias de bienestar (objetivos, áreas de interés, recordatorios)
  preferences   Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Consent {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        ConsentType
  version     String // versión del texto de consentimiento aceptado
  granted     Boolean     @default(true)
  grantedAt   DateTime    @default(now())
  revokedAt   DateTime?

  @@index([userId, type])
}

model EmergencyContact {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  relationship String?
  phone        String // SENSITIVE
  notifyOnCrisis Boolean @default(false)
  createdAt    DateTime @default(now())

  @@index([userId])
}

// ───────────────────────── Emocional ─────────────────────────

model MoodEntry {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     MoodLabel
  intensity Int // 1..5
  note      String? // SENSITIVE
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

model JournalEntry {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?
  body            String // SENSITIVE (cifrado)
  tags            MoodLabel[]
  attachments     Json? // [{ type: 'image' | 'audio', path: string }] en Supabase Storage
  transcription   String? // SENSITIVE — transcripción del audio (se conserva el audio crudo)
  sentimentScore  Float? // -1..1, resultado de análisis (async)
  analyzed        Boolean         @default(false)
  riskAssessment  RiskAssessment?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@index([userId, createdAt])
}

model AIConversation {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  messages  AIMessage[]
  decisions AiDecisionLog[]
  createdAt DateTime       @default(now())

  @@index([userId])
}

model AIMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "assistant" | "system"
  content        String // SENSITIVE
  riskLevel      RiskLevel?
  emotionalTheme String? // tema emocional detectado (p. ej. ANXIETY, SADNESS)
  attachments    Json? // [{ type: 'image' | 'audio', path: string }]
  createdAt      DateTime       @default(now())

  @@index([conversationId, createdAt])
}

// ───────────────────────── Clínico ─────────────────────────

model RiskAssessment {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  source         RiskSource
  level          RiskLevel
  ruleMatches    String[] // términos/reglas que dispararon (capa A)
  llmConfidence  Float?
  summary        String?
  journalEntryId String?      @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  reviewedByHuman Boolean    @default(false)
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime    @default(now())

  @@index([userId, level])
  @@index([level, reviewedByHuman])
}

model AiDecisionLog {
  id              String          @id @default(cuid())
  conversationId  String?
  conversation    AIConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  inputHash       String // hash de la entrada (no PII en claro)
  riskLevel       RiskLevel
  ruleMatches     String[]
  promptVersion   String
  model           String
  outputSummary   String?
  action          AiAction
  validatorResult String? // PASS | REWRITTEN | BLOCKED
  latencyMs       Int?
  reviewedByHuman Boolean         @default(false)
  createdAt       DateTime        @default(now())

  @@index([action, createdAt])
}

// ───────────────────────── Emergencia / Call center ─────────────────────────

model EmergencyTicket {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      EmergencyType
  status    TicketStatus    @default(NEW)
  riskLevel RiskLevel       @default(HIGH)
  latitude  Float?
  longitude Float?
  note      String?
  case      CallCenterCase?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([status, riskLevel])
}

model CallCenterCase {
  id          String          @id @default(cuid())
  ticketId    String          @unique
  ticket      EmergencyTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  status      CaseStatus      @default(NEW)
  priority    Int             @default(0) // mayor = más urgente
  assignedTo  String? // userId del operador
  escalatedTo String? // psychologist | physician | emergency_line
  notes       CaseNote[]
  callLogs    CallLog[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status, priority])
}

model CaseNote {
  id        String         @id @default(cuid())
  caseId    String
  case      CallCenterCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorId  String
  body      String
  createdAt DateTime       @default(now())

  @@index([caseId])
}

model CallLog {
  id         String         @id @default(cuid())
  caseId     String
  case       CallCenterCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  operatorId String
  durationSec Int?
  outcome    String?
  createdAt  DateTime       @default(now())

  @@index([caseId])
}

// ───────────────────────── Hábitos / actividad ─────────────────────────

model FoodLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl      String?
  mealType      String? // desayuno | merienda | almuerzo | onces | cena | espontanea
  note          String?
  detectedItems Json? // [{name, confidence}]
  calories      Int? // aproximado
  macros        Json? // {protein, carbs, fat}
  approximate   Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
}

model ExerciseLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String // walk | activity | sleep | water | active_break
  value      Float // pasos, minutos, litros, etc.
  unit       String
  createdAt  DateTime @default(now())

  @@index([userId, type, createdAt])
}

model MedicationItem {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedBy   String? // userId del profesional que lo asignó (si aplica)
  name         String
  dose         String // "1 tableta", "50 mg"
  route        String   @default("oral") // oral | inyectable | tópico | otro
  schedule     String[] // horarios "HH:MM" del día
  instructions String?
  startDate    DateTime?
  endDate      DateTime?
  active       Boolean  @default(true)
  intakes      MedicationIntake[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, active])
}

model MedicationIntake {
  id           String         @id @default(cuid())
  itemId       String
  item         MedicationItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId       String
  scheduledFor DateTime // fecha+hora prevista de la dosis
  status       String         @default("TAKEN") // TAKEN | LATE | MISSED
  takenAt      DateTime       @default(now())

  @@index([userId, scheduledFor])
  @@index([itemId])
}

model Goal {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  type       String   @default("habit") // emotional | habit | physical | sleep | nutrition | other
  frequency  String   @default("daily") // daily | weekly | once
  targetDate DateTime?
  progress   Int      @default(0) // 0..100
  status     String   @default("active") // active | completed | archived
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, status])
}

model Habit {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  icon      String?
  target    Int        @default(1) // frecuencia objetivo por periodo
  streak    Int        @default(0)
  active    Boolean    @default(true)
  logs      HabitLog[]
  createdAt DateTime   @default(now())

  @@index([userId])
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  completed Boolean  @default(true)

  @@index([habitId, date])
}

// ───────────────────────── Gamificación ─────────────────────────

model AchievementCard {
  id          String                @id @default(cuid())
  code        String                @unique
  name        String
  description String
  rarity      String                @default("common")
  imageUrl    String?
  owners      UserAchievementCard[]
}

model UserAchievementCard {
  userId    String
  cardId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  card      AchievementCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  earnedAt  DateTime        @default(now())

  @@id([userId, cardId])
}

model VirtualPet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  species   String   @default("companion")
  name      String
  level     Int      @default(1)
  happiness Int      @default(50) // 0..100
  accessories String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ───────────────────────── Tests / contenido ─────────────────────────

model WellnessTest {
  id          String       @id @default(cuid())
  code        String       @unique
  title       String
  description String
  category    String // stress | sleep | habits | mood | wellbeing
  questions   Json // [{id, text, options:[{label,value}]}]
  scoring     Json // reglas de interpretación (orientativas, no diagnósticas)
  results     TestResult[]
  active      Boolean      @default(true)
}

model TestResult {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId    String
  test      WellnessTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers        Json
  score          Int
  band           String // interpretación orientativa
  riskLevel      RiskLevel    @default(NONE)
  interpretation String? // resumen responsable generado por IA
  createdAt      DateTime     @default(now())

  @@index([userId, testId])
}

model ContentActivity {
  id          String   @id @default(cuid())
  type        String // breathing | meditation | active_break | gratitude | writing | education | video | routine
  title       String
  description String
  durationMin Int?
  mediaUrl    String?
  tags        String[]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([type])
}

// ───────────────────────── Notificaciones / auditoría ─────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  category  String? // clave de NotificationCategory (clasificación fina, parametrizable)
  title     String
  body      String
  href      String? // ruta de la app a la que dirige al tocar la notificación
  read      Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  @@index([userId, read])
}

model HealthMetric {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String // heart_rate | steps | sleep | calories | distance | active_minutes | hrv | spo2 | weight
  value      Float
  unit       String
  source     String // apple_health | google_fit | health_connect | wearable_ble | manual
  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId, type, recordedAt])
}

model HealthConnection {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   String // apple_health | google_fit | health_connect | wearable_ble
  status     String   @default("connected") // connected | disconnected
  deviceName String?
  lastSync   DateTime?
  createdAt  DateTime @default(now())

  @@unique([userId, provider])
}

model CommunityContent {
  id            String   @id @default(cuid())
  section       String // biblioteca | voz | tendencia | galeria | articulo
  title         String
  description   String?
  mediaUrl      String?
  thumbnailUrl  String?
  author        String?
  durationLabel String?
  tags          String[]
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([section, active])
}

model CommunityPost {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String          @default("post") // post | pregunta
  body      String
  anonymous Boolean         @default(false)
  likes     Int             @default(0)
  status    String          @default("approved") // approved | hidden | pending
  likeRefs  CommunityLike[]
  createdAt DateTime        @default(now())

  @@index([status, createdAt])
}

model CommunityLike {
  userId String
  postId String
  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

model Pqrs {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String // peticion | queja | reclamo | sugerencia
  subject    String
  body       String
  status     String   @default("new") // new | in_progress | resolved
  response   String?
  assignedTo String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status, createdAt])
  @@index([userId])
}

model ClinicalNote {
  id        String   @id @default(cuid())
  patientId String // afiliado/paciente
  authorId  String // profesional que escribe la nota
  category  String   @default("seguimiento") // seguimiento | evaluacion | observacion
  body      String
  createdAt DateTime @default(now())

  @@index([patientId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String // e.g. "callcenter.case.view"
  resource  String // e.g. "CallCenterCase:case_123"
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

// ─────────────────────────────────────────────────────────────
// EPS prestadoras + Base de conocimiento RAG para el asistente IA
// ─────────────────────────────────────────────────────────────

/// Catálogo de EPS. El afiliado elige la suya en el registro (User.epsCode → Eps.code).
/// La IA usa la base de conocimiento de su EPS para asistir trámites y servicios.
model Eps {
  code      String   @id // p.ej. "nueva_eps"
  name      String
  nit       String?
  active    Boolean  @default(true)
  brandHex  String? // color principal aproximado para co-branding
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Una fuente de conocimiento: enlace, PDF, documento o texto. scope=global aplica a
/// todos; scope=eps aplica solo a afiliados de esa EPS.
model KnowledgeSource {
  id          String   @id @default(cuid())
  scope       String   @default("global") // global | eps
  epsCode     String? // requerido cuando scope=eps
  title       String
  type        String // link | pdf | doc | text
  url         String? // para enlaces o archivos descargables
  storagePath String? // ruta en Supabase Storage (archivos subidos)
  status      String   @default("ready") // pending | processing | ready | error
  error       String?
  chunkCount  Int      @default(0)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chunks KnowledgeChunk[]

  @@index([scope, epsCode])
}

/// Fragmento indexable de una fuente (recuperación léxica top-K para el contexto de la IA).
model KnowledgeChunk {
  id        String          @id @default(cuid())
  sourceId  String
  source    KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  scope     String          @default("global")
  epsCode   String?
  ord       Int
  content   String
  createdAt DateTime        @default(now())

  @@index([scope, epsCode])
  @@index([sourceId])
}

// ─────────────────────────────────────────────────────────────
// CRM del call center + telemedicina (mensajería, citas/videollamada, despacho)
// ─────────────────────────────────────────────────────────────

/// Plantilla de mensaje reutilizable (correo/WhatsApp/SMS). htmlBody admite HTML; las
/// variables {{nombre}} se sustituyen al enviar y se previsualizan antes.
model MessageTemplate {
  id        String   @id @default(cuid())
  channel   String // email | whatsapp | sms
  name      String
  subject   String? // asunto (correo)
  htmlBody  String // cuerpo HTML (correo) o texto/markdown (whatsapp/sms)
  variables String[] // nombres de variables disponibles, p.ej. ["nombre","fecha"]
  scope     String   @default("global") // global | eps
  epsCode   String?
  active    Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Bitácora de cada mensaje saliente (auditable). status=simulated cuando no hay
/// credenciales del proveedor configuradas (degradación segura).
model OutboundMessage {
  id           String   @id @default(cuid())
  channel      String // email | whatsapp | sms
  toAddress    String // correo o teléfono destino
  targetUserId String?
  caseId       String?
  templateId   String?
  subject      String?
  body         String
  status       String   @default("queued") // queued | sent | failed | simulated
  provider     String?
  error        String?
  sentBy       String?
  createdAt    DateTime @default(now())

  @@index([caseId])
  @@index([targetUserId])
}

/// Cita / sesión (videollamada, teléfono o presencial) entre afiliado y profesional.
/// roomId alimenta la sala de video (Jitsi). Genera notificación al agendar.
model Appointment {
  id             String    @id @default(cuid())
  affiliateId    String // userId del afiliado/paciente
  professionalId String? // userId del profesional asignado
  caseId         String? // enlace opcional a un caso del call center
  kind           String    @default("medical") // medical | psychology | nutrition | callcenter | nursing | social
  modality       String    @default("video") // video | phone | in_person
  status         String    @default("scheduled") // scheduled | active | completed | cancelled | no_show
  scheduledAt    DateTime
  durationMin    Int       @default(30)
  reason         String?
  notes          String?
  roomId         String    @unique
  createdBy      String?
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([affiliateId, scheduledAt])
  @@index([professionalId, scheduledAt])
  @@index([status, scheduledAt])
}

/// Meta numérica de salud/nutrición del afiliado (calorías diarias, peso objetivo, medidas).
model HealthTarget {
  id        String   @id @default(cuid())
  userId    String
  type      String // calories_daily | weight | waist | hip | chest | arm | thigh | body_fat
  target    Float
  unit      String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
}

/// Categoría/clasificación de notificación parametrizable por el administrador.
/// level: 1 = alta/crítica, 2 = normal, 3 = informativa. enabled=false silencia la categoría.
model NotificationCategory {
  key           String   @id // p.ej. appointment, nutrition_summary, weight, achievement
  label         String
  description   String?
  type          NotificationType @default(SYSTEM)
  level         Int      @default(2)
  icon          String?
  href          String? // ruta por defecto
  enabled       Boolean  @default(true)
  broadcastable Boolean  @default(false) // el admin puede emitirla manualmente a varios usuarios
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([level])
}

/// Despacho de ambulancia / visita domiciliaria / telemetría desde el call center.
/// telemetry guarda una instantánea de las últimas métricas de salud del afiliado.
model EmergencyDispatch {
  id           String   @id @default(cuid())
  userId       String
  caseId       String?
  type         String // ambulance | home_visit | telemetry
  status       String   @default("requested") // requested | en_route | arrived | completed | cancelled
  latitude     Float?
  longitude    Float?
  address      String?
  telemetry    Json?
  notes        String?
  dispatchedBy String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([caseId])
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// Gestión documental + firma digital (con hash de evidencia)
// ─────────────────────────────────────────────────────────────

/// IPS prestadora (logo y datos para encabezar los documentos firmables).
model Ips {
  id        String   @id @default(cuid())
  name      String
  nit       String?
  epsCode   String?
  logoPath  String? // ruta del logo en Supabase Storage
  address   String?
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Tipo/plantilla de documento firmable, gestionado por el administrador.
model DocumentTemplate {
  id            String   @id @default(cuid())
  name          String
  kind          String   @default("generic") // consent | attendance | authorization | generic
  description   String?
  htmlBody      String // contenido con {{variables}} (nombre, fecha, ips, etc.)
  ipsId         String?
  requiresPhoto Boolean  @default(false) // exige foto para verificar identidad al firmar
  scope         String   @default("global") // global | eps
  epsCode       String?
  active        Boolean  @default(true)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Instancia firmada (o pendiente) de un documento. Guarda hash + evidencia del dispositivo.
model SignedDocument {
  id                 String    @id @default(cuid())
  templateId         String?
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointmentId      String? // si es firma de asistencia a una cita
  ipsId              String?
  title              String
  contentSnapshot    String // HTML renderizado en el momento de firmar
  status             String    @default("pending") // pending | signed | void
  hash               String? // SHA-256 de la evidencia canónica
  evidence           Json? // {device, userAgent, platform, screen, timezone, lat?, lng?, signedAtIso, photoHash?}
  photoPath          String? // foto de la persona al firmar (verificación de identidad)
  identityMatch      Boolean?
  identityConfidence Float?
  signedAt           DateTime?
  createdAt          DateTime  @default(now())

  @@index([userId, status])
  @@index([appointmentId])
}

// ─────────────────────────────────────────────────────────────
// Chat persona-a-persona entre roles (pacientes, call center, médicos, etc.)
// ─────────────────────────────────────────────────────────────

model ChatThread {
  id            String            @id @default(cuid())
  kind          String            @default("direct") // direct | group
  title         String? // para grupos
  directKey     String?           @unique // clave determinística "a:b" para 1:1 (dedupe)
  createdBy     String?
  lastMessageAt DateTime          @default(now())
  createdAt     DateTime          @default(now())
  participants  ChatParticipant[]
  messages      ChatMessage[]

  @@index([lastMessageAt])
}

model ChatParticipant {
  id         String     @id @default(cuid())
  threadId   String
  thread     ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId     String
  lastReadAt DateTime?
  createdAt  DateTime   @default(now())

  @@unique([threadId, userId])
  @@index([userId])
}

model ChatMessage {
  id          String     @id @default(cuid())
  threadId    String
  thread      ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId    String
  body        String?
  attachments Json? // [{type:'image'|'audio'|'document', path, name?}]
  createdAt   DateTime   @default(now())

  @@index([threadId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// Gestión Salud (HIS) — registro clínico de pacientes, contratos EPS, encuentros
// Fundación para HCE, facturación, RIPS e interoperabilidad FHIR/HL7.
// ─────────────────────────────────────────────────────────────

/// Ficha clínica/administrativa del paciente (complementa User + AffiliateProfile).
model PatientRecord {
  id                String   @id @default(cuid())
  userId            String   @unique
  mrn               String?  @unique // número de historia clínica interno
  regimen           String? // contributivo | subsidiado
  eapb              String? // EPS/EAPB
  bloodType         String?
  allergies         String?
  chronicConditions String?
  personalHistory   String? // antecedentes personales
  familyHistory     String? // antecedentes familiares
  surgicalHistory   String? // antecedentes quirúrgicos
  emergencyNotes    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Contrato con EPS o aseguradora.
model EpsContract {
  id             String    @id @default(cuid())
  insurerName    String
  epsCode        String?
  contractNumber String?
  modality       String? // capitacion | evento | pgp | subsidiado
  startDate      DateTime?
  endDate        DateTime?
  ceilingValue   Float?
  status         String    @default("active") // active | suspended | ended
  notes          String?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

/// Encuentro asistencial (admisión / atención): consulta, urgencias, hospitalización, UCI, etc.
model Encounter {
  id             String    @id @default(cuid())
  userId         String
  appointmentId  String?
  type           String    @default("consulta_externa") // consulta_externa | urgencias | hospitalizacion | uci | domiciliaria | pyp | laboratorio | imagenologia | cirugia
  status         String    @default("open") // open | in_progress | closed
  reason         String?
  cie10          String? // diagnóstico principal
  diagnosis      String?
  professionalId String?
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  createdAt      DateTime  @default(now())

  @@index([userId, startedAt])
  @@index([type, status])
}

/// Cama hospitalaria (hospitalización, UCI, urgencias) para el censo y la ocupación.
model Bed {
  id                 String   @id @default(cuid())
  code               String   @unique
  ward               String   @default("hospitalizacion") // hospitalizacion | uci | urgencias
  status             String   @default("available") // available | occupied | cleaning | maintenance
  currentUserId      String?
  currentEncounterId String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([ward, status])
}

/// Médico out-door / de campo: ubicación, turno y estado para atención domiciliaria geolocalizada.
model FieldAgent {
  id             String   @id @default(cuid())
  userId         String   @unique
  zone           String? // zona de la ciudad
  lat            Float
  lng            Float
  status         String   @default("offline") // available | en_route | attending | offline
  specialty      String?
  shiftStart     String? // "07:00"
  shiftEnd       String? // "19:00"
  phone          String?
  activeServices Int      @default(0)
  lastUpdate     DateTime @default(now())
  createdAt      DateTime @default(now())
}

/// Matriz de acceso a módulos por rol (parametrizable por el administrador).
model RoleModuleAccess {
  id        String   @id @default(cuid())
  roleName  String
  moduleKey String // "facturacion" o submódulo "facturacion.rips"
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@unique([roleName, moduleKey])
  @@index([roleName])
}

/// Visita de atención domiciliaria (hospitalización en casa).
model HomeVisit {
  id             String   @id @default(cuid())
  userId         String
  professionalId String?
  scheduledAt    DateTime
  status         String   @default("scheduled") // scheduled | done | cancelled
  address        String?
  reason         String?
  notes          String?
  vitals         Json?
  createdBy      String?
  createdAt      DateTime @default(now())

  @@index([userId, scheduledAt])
  @@index([status, scheduledAt])
}

/// Clasificación de triage de urgencias (Resolución 5596 de 2015): nivel 1 (más urgente) a 5.
model Triage {
  id             String   @id @default(cuid())
  userId         String
  encounterId    String?
  level          Int // 1..5
  reason         String?
  vitals         Json?
  professionalId String?
  status         String   @default("waiting") // waiting | attended
  createdAt      DateTime @default(now())

  @@index([status, level])
}

/// Evolución clínica (nota SOAP) + signos vitales, dentro de un encuentro.
model ClinicalEvolution {
  id          String   @id @default(cuid())
  encounterId String
  userId      String
  authorId    String?
  subjective  String? // S
  objective   String? // O
  assessment  String? // A
  plan        String? // P
  vitals      Json? // {bp, hr, temp, rr, spo2, weight, height, bmi}
  createdAt   DateTime @default(now())

  @@index([encounterId])
}

/// Diagnóstico (CIE-10) de un encuentro. Permite principal + relacionados.
model Diagnosis {
  id          String   @id @default(cuid())
  encounterId String
  userId      String
  cie10       String
  description String?
  kind        String   @default("relacionado") // principal | relacionado
  createdAt   DateTime @default(now())

  @@index([encounterId])
  @@index([userId])
}

/// Factura de servicios de salud (cuenta) por paciente/encuentro.
model Invoice {
  id           String        @id @default(cuid())
  number       String        @unique
  userId       String
  encounterId  String?
  contractId   String?
  insurerName  String?
  status       String        @default("draft") // draft | issued | radicada | partial | paid | rejected
  issueDate    DateTime?
  radicadoDate DateTime?
  total        Float         @default(0)
  notes        String?
  createdBy    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  lines        InvoiceLine[]
  glosas       Glosa[]
  payments     InvoicePayment[]

  @@index([userId])
  @@index([status])
}

/// Pago (total o parcial) recibido sobre una factura.
model InvoicePayment {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Float
  method    String? // transferencia | efectivo | nota credito | otro
  reference String?
  createdBy String?
  createdAt DateTime @default(now())

  @@index([invoiceId])
}

/// Ítem de inventario (medicamento o insumo) con lote y vencimiento.
model InventoryItem {
  id           String              @id @default(cuid())
  kind         String              @default("medicamento") // medicamento | insumo
  code         String? // CUM / CUPS
  name         String
  unit         String? // unidad | caja | ampolla
  stock        Float               @default(0)
  reorderLevel Float               @default(0)
  lot          String?
  expiryDate   DateTime?
  location     String?
  active       Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  movements    InventoryMovement[]

  @@index([kind])
}

model InventoryMovement {
  id        String        @id @default(cuid())
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type      String // in | out | adjust
  quantity  Float
  reason    String?
  createdBy String?
  createdAt DateTime      @default(now())

  @@index([itemId, createdAt])
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  kind        String // consulta | procedimiento | medicamento | insumo | otros
  code        String? // CUPS / CUM
  description String
  quantity    Int     @default(1)
  unitValue   Float   @default(0)
  total       Float   @default(0)
  cie10       String?

  @@index([invoiceId])
}

/// Glosa (objeción) sobre una factura — Res. 3047 / ciclo de auditoría de cuentas.
model Glosa {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  code        String // código de glosa
  description String
  value       Float    @default(0)
  status      String   @default("open") // open | answered | accepted | conciliated
  response    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([invoiceId])
}

/// Orden médica: laboratorio, imágenes, medicamento, procedimiento o remisión.
model ClinicalOrder {
  id          String   @id @default(cuid())
  encounterId String
  userId      String
  type        String // lab | imaging | medication | procedure | referral
  description String
  code        String? // CUPS / CUM
  status      String   @default("requested") // requested | in_progress | done | cancelled
  result      String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([encounterId])
  @@index([userId, type])
}
