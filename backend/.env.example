# --- App ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# --- Database (Supabase) ---
# DATABASE_URL: conexión POOLED (pgbouncer, puerto 6543) → runtime / serverless / Vercel.
# DIRECT_URL:   conexión DIRECTA (puerto 5432) → migraciones de Prisma.
# Obtén ambas en: Supabase Dashboard → Connect → ORMs → Prisma.
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- Supabase API (para clientes / Storage) ---
SUPABASE_URL="https://[REF].supabase.co"
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Auth ---
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- Encryption (envelope encryption key for sensitive columns) ---
DATA_ENCRYPTION_KEY=change_me_32_bytes_base64_key

# --- AI / LLM provider ---
# AI_PROVIDER=deepseek usa la API de DeepSeek (compatible con OpenAI).
# Modelos: deepseek-chat (V3) | deepseek-reasoner (R1). Usa 'mock' para dev sin clave.
AI_PROVIDER=deepseek
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=deepseek-chat
AI_BASE_URL=https://api.deepseek.com
AI_ALLOW_MODEL_TRAINING=false

# --- Storage (S3 compatible / MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=bienestapp
S3_SECRET_KEY=bienestapp_dev
S3_BUCKET=bienestapp

# --- Emergency lines (Colombia) ---
EMERGENCY_LINE_GENERAL=123
EMERGENCY_LINE_MENTAL_HEALTH=106
