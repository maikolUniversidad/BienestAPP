# --- App ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# --- Database ---
DATABASE_URL="postgresql://bienestapp:bienestapp_dev@localhost:5432/bienestapp?schema=public"

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Auth ---
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- Encryption (envelope encryption key for sensitive columns) ---
DATA_ENCRYPTION_KEY=change_me_32_bytes_base64_key

# --- AI / LLM provider ---
# Provider-agnostic. In production route through an AI Gateway with Zero Data Retention.
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001
AI_ALLOW_MODEL_TRAINING=false

# --- Storage (S3 compatible / MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=bienestapp
S3_SECRET_KEY=bienestapp_dev
S3_BUCKET=bienestapp

# --- Emergency lines (Colombia) ---
EMERGENCY_LINE_GENERAL=123
EMERGENCY_LINE_MENTAL_HEALTH=106
